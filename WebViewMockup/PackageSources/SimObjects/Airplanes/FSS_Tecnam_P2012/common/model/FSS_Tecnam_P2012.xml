		<ParametersFn Name="GET_WALKAROUND_PARAMS">
			<ReturnParameters>
				<CAM_TYPE>2</CAM_TYPE>
				<EFB_CAM_RANGE>5 10</EFB_CAM_RANGE>
			</ReturnParameters>
		</ParametersFn>

		<ParametersFn Name="GET_PROP_PARAMS">
			<ReturnParameters>
				<DISABLE_ANIM_CODE>
					(A:GENERAL ENG COMBUSTION:#ID#, Bool) if{
						1 (&gt;O:ENG_WAS_ON)
					} els{
						(A:PROP RPM:#ID#, rpm) 0 == if{
							0 (&gt;O:ENG_WAS_ON)
						}
					}
					(A:IS LATITUDE LONGITUDE FREEZE ON, Bool) (O:ENG_WAS_ON) ! and
					(L:FSS_P2006T_ENGINE_SIM_RPM_OVD_#ID#) 0 == or
				</DISABLE_ANIM_CODE>
				<ANIM_INC_SCALE_CODE>
					(L:FSS_P2006T_OIL_LEVEL_PERCENT_#ID#) 20 min 20 / 1 (L:FSS_P2006T_OPSMODE) ?
				</ANIM_INC_SCALE_CODE>
			</ReturnParameters>
		</ParametersFn>

